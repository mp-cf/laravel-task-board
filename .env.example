APP_NAME="Task Board"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app

LOG_CHANNEL=stderr
LOG_LEVEL=debug

# PostgreSQL — Railway injects these automatically when you link a Postgres service.
# You can also use the DATABASE_URL variable directly (Laravel will parse it).
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Redis — Railway injects these automatically when you link a Redis service.
REDIS_CLIENT=predis
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# Cache, session and queue all use Redis
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Horizon
HORIZON_PREFIX=task_board_horizon:
